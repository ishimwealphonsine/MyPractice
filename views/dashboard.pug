doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Product Dashboard

    link(
      rel="stylesheet",
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    )
    link(rel="stylesheet", href="/css/style.css")

  body.bg-light
    .container.py-4

      .row.g-4.mb-4
        // LEFT SUMMARY SECTION
        .col-12.col-lg-6
          .card.border.product-card-large
            .card-body.d-flex.align-items-center.justify-content-center
              .row.w-100.align-items-center
                .col-6.ps-4
                  h3.fw-bold.mb-1 UGX 50,000,000
                  p.text-secondary.fs-5.mb-0 Sales

                .col-6.border-start.ps-4
                  h3.fw-bold.mb-1 UGX 15,000,000
                  p.text-secondary.fs-5.mb-0 Orders

          .row.g-4.mt-0
            .col-12.col-md-6
              .card.border.product-small-card
                .card-body.d-flex.flex-column.justify-content-center.align-items-center
                  h4.fw-bold.text-success.mb-0 UGX #{Number(inStockValue || 0).toLocaleString()}
                  p.text-secondary.fs-5.mb-0 In stock

            .col-12.col-md-6
              .card.border.product-small-card
                .card-body.d-flex.flex-column.justify-content-center.align-items-center
                  h4.fw-bold.text-danger.mb-0 #{outOfStockCount || 0}
                  p.text-secondary.fs-5.mb-0 Out of stock

        // ADD PRODUCT FORM SECTION
        .col-12.col-lg-6
          .card.border.product-form-card
            .card-body.p-4
              h4.fw-normal.mb-4 Add Product

              if success
                .alert.alert-success.rounded-0.d-flex.justify-content-center.align-items-center.position-relative
                  span Product has been added successfully!
                  a.text-white.text-decoration-none.fw-bold.position-absolute.end-0.me-3(href="/dashboard") X

              form(action="/dashboard", method="post")
                .mb-2
                  input.form-control.rounded-0.product-input(
                    class=errors && errors.name ? 'border border-danger' : '',
                    type="text",
                    name="name",
                    placeholder="Product Name",
                    value=formData && formData.name ? formData.name : ''
                  )
                  if errors && errors.name
                    small.text-danger #{errors.name}

                .mb-2
                  input.form-control.rounded-0.product-input(
                    class=errors && errors.category ? 'border border-danger' : '',
                    type="text",
                    name="category",
                    placeholder="Category",
                    value=formData && formData.category ? formData.category : ''
                  )
                  if errors && errors.category
                    small.text-danger #{errors.category}

                .mb-2
                  input.form-control.rounded-0.product-input(
                    class=errors && errors.price ? 'border border-danger' : '',
                    type="number",
                    name="price",
                    placeholder="Price",
                    value=formData && formData.price ? formData.price : ''
                  )
                  if errors && errors.price
                    small.text-danger #{errors.price}

                .mb-2
                  input.form-control.rounded-0.product-input(
                    class=errors && errors.quantity ? 'border border-danger' : '',
                    type="number",
                    name="quantity",
                    placeholder="Quantity",
                    value=formData && formData.quantity ? formData.quantity : ''
                  )
                  if errors && errors.quantity
                    small.text-danger #{errors.quantity}

                .row.g-3.mb-4
                  .col-12.col-md-6
                    input.form-control.rounded-0.product-input(
                      class=errors && errors.color ? 'border border-danger' : '',
                      type="text",
                      name="color",
                      placeholder="Color",
                      value=formData && formData.color ? formData.color : ''
                    )
                    if errors && errors.color
                      small.text-danger #{errors.color}

                  .col-12.col-md-6
                    input.form-control.rounded-0.product-input(
                      type="file",
                      name="image"
                    )

                .row.g-3
                  .col-12.col-md-6
                    button.btn.product-save-btn.w-100.fw-bold(type="submit") SAVE

                  .col-12.col-md-6
                    button.btn.product-clear-btn.w-100.fw-bold(type="reset") CLEAR

      // PRODUCT TABLE
      .table-responsive
        table.table.table-bordered.text-center.align-middle.product-table
          thead
            tr
              th ID
              th NAME
              th CATEGORY
              th PRICE (UGX)
              th QUANTITY

          tbody
            if products && products.length
              each product in products
                tr
                  td ##{product._id.toString().slice(-6)}
                  td #{product.name}
                  td #{product.category}
                  td #{Number(product.price).toLocaleString()}
                  td #{product.quantity}
            else
              tr
                td(colspan="5").text-muted No products found
      
      .row.g-3.mt-3
        .col-12.col-md-12
          a.btn.product-save-btn.w-100.fw-bold(href="/logout") LOGOUT
