doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Login
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel='stylesheet' href='/css/style.css')
  body.bg-light
    .container.min-vh-100.d-flex.justify-content-center.align-items-center
      .row.w-100.justify-content-center
        .col-12.col-md-6.col-lg-5

          h1.text-center.fw-normal.mb-4 Login

          if error
            .alert.alert-danger.d-flex.justify-content-between.align-items-center.rounded-0
              span #{error}
              a.text-white.text-decoration-none.fw-bold(href="/login") X

          form(action="/login", method="POST")
            .mb-4
              input.form-control.form-control-lg.rounded-0.auth-input(
                type="text",
                name="email",
                placeholder="Email or Phone Number",
                required
              )

            .mb-4
              input.form-control.form-control-lg.rounded-0.auth-input(
                type="password",
                name="password",
                placeholder="Password",
                required
              )

            button.btn.auth-btn.w-100.btn-lg.rounded-1.fw-bold(type="submit") LOGIN

          p.text-center.text-secondary.mt-3
            | Don’t have an account? - 
            a.text-primary.text-decoration-none(href="/signup") Signup

    script.
      const form = document.querySelector('form');
      const inputs = form.querySelectorAll('input');

      form.addEventListener('submit', function(e) {
        let valid = true;
        inputs.forEach(input => {
          if (!input.value.trim()) {
            input.classList.add('input-error');
            valid = false;
          } else {
            input.classList.remove('input-error');
          }
        });
        if (!valid) e.preventDefault();
      });

      inputs.forEach(input => {
        input.addEventListener('input', function() {
          if (input.value.trim()) {
            input.classList.remove('input-error');
          }
        });
      });